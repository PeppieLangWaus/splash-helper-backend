# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/splash-helper

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
SETUP_LINK_SECRET=change-me-to-another-long-random-secret
# Duration for setup links: e.g. 24h, 7d, 1h
SETUP_LINK_EXPIRY=24h

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET=change-me-to-a-strong-admin-secret

# ── Frontend URL (used in generated setup links) ─────────────────────────────
FRONTEND_URL=https://splasher.help

# ── Discord webhooks ──────────────────────────────────────────────────────────
# Create webhooks in Discord: Server Settings > Integrations > Webhooks
# Active splashers embed (sends/edits a persistent status message)
DISCORD_ACTIVE_WEBHOOK_URL=https://discord.com/api/webhooks/your/active-webhook
# Archived session notifications
DISCORD_ARCHIVED_WEBHOOK_URL=https://discord.com/api/webhooks/your/archived-webhook
